  "info": {
    "title": "Nike Store API",
    "description": "REST API for the Nike Store iOS app — auth, catalog, cart, favorites, payments, orders and Nike+.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Jordan Runner"
          },
          "email": {
            "type": "string",
            "example": "jordan@nike.com"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "minLength": 8
          }
        },
        "required": [
          "name",
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jordan@nike.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "AddCartItemDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "example": "875942-100"
          },
          "quantity": {
            "type": "number",
            "example": 1,
            "minimum": 1
          }
        },
        "required": [
          "productId",
          "quantity"
        ]
      },
      "UpdateCartItemDto": {
        "type": "object",
        "properties": {
          "quantity": {
            "type": "number",
            "example": 2,
            "minimum": 1
          }
        },
        "required": [
          "quantity"
        ]
      },
      "AddFavoriteDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "example": "875942-100"
          }
        },
        "required": [
          "productId"
        ]
      },
      "CreatePaymentMethodDto": {
        "type": "object",
        "properties": {
          "holderName": {
            "type": "string",
            "example": "Jordan Runner"
          },
          "cardNumber": {
            "type": "string",
            "example": "4111111111111111",
            "description": "Used only to derive brand + last 4 digits; the full number is never stored."
          },
          "expiryDate": {
            "type": "string",
            "example": "12/28"
          },
          "isDefault": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "holderName",
          "cardNumber",
          "expiryDate"
        ]
      },
      "UpdatePaymentMethodDto": {
        "type": "object",
        "properties": {
          "holderName": {
            "type": "string"
          },
          "expiryDate": {
            "type": "string",
            "example": "12/28"
          },
          "isDefault": {
            "type": "boolean"
          }
        }
      },
      "CreateAddressDto": {
        "type": "object",
        "properties": {
          "street": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "zipCode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "isDefault": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "street",
          "city",
          "state",
          "zipCode",
          "country",
          "latitude",
          "longitude"
        ]
      },
      "UpdateAddressDto": {
        "type": "object",
        "properties": {
          "street": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "zipCode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "isDefault": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "paymentMethodId": {
            "type": "string",
            "description": "Saved payment method id used to charge this order"
          }
        },
        "required": [
          "paymentMethodId"
        ]
      }
    }
  }
