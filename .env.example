# Pooled connection (host with "-pooler") — used by the app at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# Direct/unpooled connection (host without "-pooler") — used by Prisma Migrate
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-a-random-64-char-hex-secret"
JWT_REFRESH_SECRET="replace-with-a-different-random-64-char-hex-secret"

PORT=3000
NODE_ENV=development
